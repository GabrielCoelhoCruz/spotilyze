    "video:render": "remotion render src/remotion/index.ts SpotilyzeDemo out/spotilyze-demo.mp4",
    "video:gif": "remotion render src/remotion/index.ts SpotilyzeDemo out/spotilyze-demo.gif --image-format=png"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@remotion/cli": "^4.0.482",
    "@remotion/media": "^4.0.482",
